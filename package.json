    "@tanstack/history": "1.161.6",
    "@tanstack/react-query": "5.95.2",
    "@tanstack/react-router": "1.168.3",
    "better-sqlite3": "12.8.0",
    "bun": "1.3.11",
    "cache": "3.0.0",
    "clsx": "2.1.1",
    "drizzle-orm": "0.45.1",
    "drizzle-zod": "0.8.3",
    "elysia": "1.4.28",
    "install": "0.13.0",
    "lucide-react": "1.0.1",
    "motion": "12.38.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-simple-icons": "1.0.0-beta.5",
    "simple-icons": "16.13.0",
    "tailwind-merge": "3.5.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
