{
  "name": "hackerfolio-tulio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bash -c \"trap 'kill 0' INT TERM; bun server/app.ts & vite --config vite.config.ts & wait\"",
    "build": "vite build --config vite.config.ts && vite build --config vite.config.ts --ssr",
    "build:production": "NODE_ENV=production bun run build",
    "start:production": "NODE_ENV=production bun server/app.ts",
    "test": "vitest run",
    "check:types": "tsc --noEmit",
    "check:lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "check:format": "prettier --check .",
    "check:all": "bun run check:types && bun run check:lint && bun run check:format && bun run test",
    "fix:lint": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "fix:format": "prettier --write .",
    "fix:all": "bun run fix:format && bun run fix:lint",
    "cf:dev": "wrangler dev",
    "cf:deploy": "wrangler deploy"
  },
  "dependencies": {
    "@cloudflare/containers": "0.2.0",
    "@elysiajs/cors": "1.4.1",
    "@grafana/faro-web-sdk": "2.3.1",
